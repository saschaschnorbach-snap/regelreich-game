      "SecondaryAttribute": "BERLIN_ISSUES",
      "TertiaryAttribute": null,
      "Payload": {
        "QuestionText": "Below is a list of topics often discussed in Berlin and/or Germany. For each statement, please indicate how strongly you agree or do not agree.",
        "DataExportTag": "BERLIN_ISSUES",
