ederal minimum went up at all.<\/strong><br>\n<br>\nFor the content above, to what extent do you agree with the following statements?","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"RecodeValues":{"1":"-3","2":"-2","3":"-1","4":"1","5":"2","6":"3"},"DataExportTag":"ManFalseCT1","QuestionID":"QID532"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID533","SecondaryAttribute":"${q:\/\/QID446\/QuestionText} The Postal Service Institutionalizes Ballot Interference Scheme with N...","TertiaryAttribute":null,"Payload":{"AnswerOrder":["1","2","3","4","5","6"],"Answers":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Somewhat disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Agree"},"6":{"Display":"Strongly agree"}},"ChoiceDataExportTags":{"1":"CtlFalseCT2_Share","2":"CtlFalseCT2_Like","3":"CtlFalseCT2_Accuracy","4":"CtlFalseCT2_Manip","5":"CtlFalseCT2_ManipConf"},"ChoiceOrder":["4","5","3","1","2"],"Choices":{"1":{"Display":"I would share this post on social media"},"2":{"Display":"I would 'like' this post on social media"},"3":{"Display":"This is an accurate post"},"4":{"Display":"This is a manipulative post"},"5":{"Display":"I am confident in my assessment of this post's manipulativeness"}},"Configuration":{"ChoiceColumnWidth":25,"MobileFirst":true,"QuestionDescriptionOption":"UseText","RepeatHeaders":"none","TextPosition":"inline","WhiteSpace":"OFF"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":7,"NextChoiceId":8,"QuestionDescription":"${q:\/\/QID446\/QuestionText} The Postal Service Institutionalizes Ballot Interference Scheme with N...","QuestionText":"${q:\/\/QID446\/QuestionText}<strong><i> <\/i><br>\nThe Postal Service Institutionalizes Ballot Interference Scheme with New Mail-in Ballot Division<\/strong><br>\n<br>\nFor the content above, to what extent do you agree with the following statements?","QuestionText_Unsafe":"${q:\/\/QID446\/QuestionText}<strong><i> <\/i><br \/>\nMy grandmother told me she was 15 the last time she saw minimum wage and inflation increase together, and she had to file for BANKRUPTCY almost losing the house I grew up in. Now it&#39;s happening AGAIN and people everywhere are suffering! Meanwhile, the federal minimum wage hasn&#39;t increased for 10 years. This is tragic!<\/strong><br \/>\n<br \/>\nFor the content above, to what extent do you agree with the following statements?","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"RecodeValues":{"1":"-3","2":"-2","3":"-1","4":"1","5":"2","6":"3"},"DataExportTag":"CtlFalseCT2","QuestionID":"QID533"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID534","SecondaryAttribute":"${q:\/\/QID446\/QuestionText}This is Why Democrats Are Not Worried about 2020 \u2014 The Fix Is In\u2026 Post","TertiaryAttribute":null,"Payload":{"AnswerOrder":["1","2","3","4","5","6"],"Answers":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Somewhat disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Agree"},"6":{"Display":"Strongly agree"}},"ChoiceDataExportTags":{"1":"ManFalseCT2_Share","2":"ManFalseCT2_Like","3":"ManFalseCT2_Accuracy","4":"ManFalseCT2_Manip","5":"ManFalseCT2_ManipConf"},"ChoiceOrder":["4","5","3","1","2"],"Choices":{"1":{"Display":"I would share this post on social media"},"2":{"Display":"I would 'like' this post on social media"},"3":{"Display":"This is an accurate post"},"4":{"Display":"This is a manipulative post"},"5":{"Display":"I am confident in my assessment of this post's manipulativeness"}},"Configuration":{"ChoiceColumnWidth":25,"MobileFirst":true,"QuestionDescriptionOption":"UseText","RepeatHeaders":"none","TextPosition":"inline","WhiteSpace":"OFF"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":7,"NextChoiceId":8,"QuestionDescription":"${q:\/\/QID446\/QuestionText}This is Why Democrats Are Not Worried about 2020 \u2014 The Fix Is In\u2026 Posta...","QuestionText":"${q:\/\/QID446\/QuestionText}<br>\n<strong>This is Why Democrats Are Not Worried about 2020 \u2014 The Fix Is In\u2026 Postal Service Institutionalizes Ballot Interference Scheme with New Mail-in Ballot Division<\/strong><br>\n<br>\nFor the content above, to what extent do you agree with the following statements?","QuestionText_Unsafe":"${q:\/\/QID446\/QuestionText}<br>\n<strong>It\u2019s been over 50 years since minimum wage and inflation increased together, then over a decade since the federal minimum went up at all.<\/strong><br>\n<br>\nFor the content above, to what extent do you agree with the following statements?","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"RecodeValues":{"1":"-3","2":"-2","3":"-1","4":"1","5":"2","6":"3"},"DataExportTag":"ManFalseCT2","QuestionID":"QID534"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID535","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q272","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID535"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID85","SecondaryAttribute":"Thank you for participating in this study! This is the end of the study. Please find more informa...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">Thank you for participating in this study! This is the end of the study. Please find more information below.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"color:#e74c3c;\"><span style=\"font-family:Tahoma,Geneva,sans-serif;\">First of all:&nbsp;<strong>&nbsp;the U.S. Center for Disease Control (CDC) states that vaccines are safe: \u201c<\/strong>Most side effects from vaccines, such as pain and redness at the injection site, are mild and go away quickly on their own. Serious adverse events are rare.\u201d For more information on vaccine safety, please visit https:\/\/www.cdc.gov\/patientsafety\/features\/vaccine-safety.html.<\/span><\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">The aim of this study is to learn more about how people perceive and engage with the techniques used in the production of fake news and misinformation about vaccines. We are interested in the best way to help teach people how to recognize fake news and misinformation about this important topic. To do so, we developed a game based on our current understanding of what techniques are common in the spread of misinformation about vaccinations.&nbsp;<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-family: Tahoma, Geneva, sans-serif;\">As a participant, you were assigned to one of three conditions: a training condition (in which participants play the misinformation game from the perspective of a \u201cdetective\u201d who fights vaccine misinformation), a perspective-taking condition (where they play the same game but from the perspective of the misinformation creator instead of the \u201cdetective\u201d) or a control condition (in which participants play Tetris).&nbsp;<\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">The theory behind both misinformation games relies on a principle known as inoculation: just as medical vaccines trigger antibodies in our immune system by injecting a severely weakened dose of a virus, the same can be achieved with information, cultivating \u201cmental antibodies\u201d. By demystifying the techniques that are used in the production of misinformation, we hope to help people resist and identify it when they encounter it online. The game serves as a simulation to help people familiarize themselves with these tactics, as familiarity is key to being able to identify unwanted persuasion attempts.&nbsp;<\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">We are interested in evaluating whether people improve in their ability to evaluate the reliability of several real and fake headlines and tweets after playing both misinformation games, compared to the control condition. It is important to remember that although inspired by real events, the content of the game is entirely fictional.&nbsp;<strong>If you played the game as part of this study, you have not actually spread any misinformation.&nbsp;<\/strong><\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><strong><o:p><\/o:p><\/strong><\/span><br>\n&nbsp;<\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\"><strong>The headlines based on factual information about vaccinations that you may have seen were:&nbsp;<\/strong><\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 The US database on vaccine injuries launched.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Vaccines \u201ckey health issue\u201d as world leaders discuss vaccination programs at summit.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Vaccination programs have been broadly beneficial for public health.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Flu shot might reduce coronavirus infections, early research suggests.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 CDC study looks at how well the HPV vaccine works against infections and pre-cancers caused by certain types of HPV.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Several peer-reviewed studies have looked at the link between autism spectrum disorder and vaccinations. To summarize: there is no evidence that vaccines cause autism.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Vaccines contain trace amounts of glyphosate. A scientist explains why.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Homeopathic prophylaxis: Scientists sceptical about homeopathy as a preventative measure against serious infectious diseases.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Scientists\u2019 findings hint at link between viruses and later health issues, including cancer.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Why do babies get several vaccines at a time? Health practitioners explain why.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Approximately 1 in 1 million vaccinations administered leads to compensation by US Vaccine Court<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Hepatitis B Vaccine prevents hepatitis B infections, but, like any medicine, can have side effects<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\"><strong>&nbsp;<\/strong><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\"><strong>The fake or misleading headlines that you may have seen were:<\/strong><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Vaccine database wiped by government to hide uptick in admitted vaccine injuries.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 The more our world leaders insist on vaccinating, the more suspicious you should be.&nbsp;&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Vaccinations being for \u201cthe Greater Good\u201d is an excuse. Their real goal is social control.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Prestigious vaccine journal: Flu vaccine increases coronavirus infection risk 36%.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 This Oncology dietitian exposed unbelievable fraud in a HPV vaccine study by the Center for Disease Control.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 See below for 29 studies that link Autism to vaccine toxicity. Thousands of parents describe their children as fine one day and then their children suddenly develop autism (a neurological regression) after vaccines...&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 CONFIRMED: Vaccines are contaminated with glyphosate.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Homeopathic prophylaxis: Science accepts Homeopathy as a Safe and Effective Alternative to Conventional Vaccines.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Scientists find that common natural viruses such as measles REDUCE later health issues, including cancer.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 After paralyzing 6-month old baby with too many vaccines, doctor suggests MORE vaccines.&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Chickenpox vaccine permanently disabled a young boy, vaccine court forced to admit.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">\u2022 Warning to Parents: Hepatitis B Vaccine Linked to Sudden Infant Death... <\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p>Finally, we asked you to rate a series of headlines as either true or false and manipulative or non-manipulative. We also asked you to identify which manipulation technique (if any) was used in the headline. The correct answers can be found in the matrix below.<\/p>\n\n<p>&nbsp;<\/p>\n\n<p><img height=\"244\" src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_9XDfqxb7N2ifn2m\" style=\"height: 244px; width: 650px;\" width=\"650\"><\/p>\n\n<p><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\"><br><\/span><\/p><p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">This study is being conducted by Dr Jon Roozenbeek, Melisa Basol, Prof. Sander van der Linden, Ruth Appel, Dr Rebecca Rayburn-Reeves, and Dr Jonathan Corbin.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\">&nbsp;<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-family:Tahoma,Geneva,sans-serif;\"><strong>Study contact:<\/strong> Jon Roozenbeek, jjr51@cam.ac.uk.<\/span><span style=\"font-family:&quot;Times New Roman&quot;,serif\"><o:p><\/o:p><\/span><\/p>","DefaultChoices":false,"DataExportTag":"Debrief","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for participating in this study! This is the end of the study. Please find more informa...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":11,"NextAnswerId":1,"QuestionID":"QID85","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}