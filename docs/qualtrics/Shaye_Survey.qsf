c.php?IM=IM_8IE8VQIBYrPXMnH\" style=\"width: 499px; height: 57px;\" \/>","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":" ","QuestionText_Unsafe":"<img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_4Uy62DpBnT7SN0h\" style=\"width: 399px; height: 223px;\" \/>","DataExportTag":"Conspir-Leaders","QuestionID":"QID278"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID279","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"DefaultChoices":false,"QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"Choices":{"1":{"Display":"This post is manipulative"},"2":{"Display":"I am confident about my assessment of this post's manipulativeness"},"3":{"Display":"I would share this post with people in my network"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":8,"ColumnLabels":[{"Display":"Strongly disagree","IsLabelDefault":false},{"Display":"Neutral","IsLabelDefault":false},{"Display":"Strongly agree","IsLabelDefault":false}],"Answers":{"1":{"Display":"1"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7"}},"AnswerOrder":["1","2","3","4","5","6","7"],"ChoiceDataExportTags":false,"QuestionText":"<img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_cwOHDU86D5FzpVH\" style=\"width: 499px; height: 56px;\" \/>","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":" ","QuestionText_Unsafe":"<img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_eJxkHcAECO865ud\" style=\"width: 400px; height: 135px;\" \/>","DataExportTag":"Conspir-Leaders-C","QuestionID":"QID279"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"Your next objective is to play a game. In the frame underneath you can start.\u00a0 \u00a0 The proceed butt.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>Your next objective is to play a game. In the frame underneath you can start.&nbsp;<\/div>\n\n<div>&nbsp;<\/div>\n\n<div><strong>The proceed button will only appear after a minimum of 5 minutes of attentive play. After approx. 16 minutes of <u>active playing<\/u>, you will automatically move to the next page.<\/strong> While the goal is to attain as high a level as possible, do not worry about bad performance, what counts is active playing. Double click on Tetris to start the game. The goal is to form solid horizontal lines with no gaps. You can use the <b>arrow keys<\/b> to move the blocks. Use the <b>space bar<\/b> to change the positioning of the block.<\/div>\n\n<div>&nbsp;<\/div>\n\n<div><u>If asked to enter your name for the high scores, do not enter any letter.<\/u> Instead, press the &#39;ENTER&#39; key 2 times to continue. If you forgot to do this and the game freezes, do not worry, it will reset itself after a few minutes or proceed to the next page if your performance was good.<\/div>\n\n<div>&nbsp;<\/div>\n\n<div>&nbsp;<\/div>\n\n<div class=\"resp-container\"><iframe class=\"resp-iframe\" src=\"https:\/\/rakoen.maertens.international\/research-tetris\/\"><\/iframe><\/div>","DefaultChoices":false,"DataExportTag":"Tetris","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Your next objective is to play a game. In the frame underneath you can start.\u00a0 \u00a0 The proceed butt...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":1,"NextAnswerId":1,"QuestionID":"QID28"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QI