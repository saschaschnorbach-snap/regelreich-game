eutral","IsLabelDefault":false},{"Display":"Strongly agree","IsLabelDefault":false}],"Answers":{"1":{"Display":"1"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7"}},"AnswerOrder":["1","2","3","4","5","6","7"],"ChoiceDataExportTags":false,"QuestionText":"<img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_bPMRHb9hF0dBOIt\" style=\"width: 499px; height: 113px;\" \/>","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":" ","QuestionText_Unsafe":"<img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_eu6eV4okJhhy9Qp\" style=\"width: 498px; height: 99px;\" \/>","DataExportTag":"Story-Hepatitis-C","QuestionID":"QID325"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID326","SecondaryAttribute":"Thank you. You have opted not to participate in this study. You will now be redirected back to Pr...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you. You have opted not to participate in this study. You will now be redirected back to Prolific.","DefaultChoices":false,"DataExportTag":"No_Consent","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you. You have opted not to participate in this study. You will now be redirected back to Pr...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID326","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID327","SecondaryAttribute":"Please note that this survey is best viewed on a desktop or computer and that some features might...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please note that this survey is best viewed on a desktop or computer and that some features might be less compatible with a mobile device. <b>Please do not complete this study on a smartphone<\/b>. We cannot guarantee that it will work and that your responses will be accepted.&nbsp;<br><br>If you have&nbsp;AdBlock&nbsp;or&nbsp;Social Media Blockers&nbsp;installed on your internet browser and know how to disable them, please completely disable these add-ons before continuing, in order for the study to run properly.<br>\n<br>\nIf you do not have AdBlock installed or do not know what to do here, please do not worry. You can just continue without any problems.&nbsp;","DefaultChoices":false,"DataExportTag":"AdBlock","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please note that this survey is best viewed on a desktop or computer and that some features might...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID327","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID328","SecondaryAttribute":"Please answer the following question: What was the topic of the last scenario in the game?","TertiaryAttribute":null,"Payload":{"QuestionText":"Please answer the following question: What was the topic of the last scenario in the game?","DataExportTag":"GoodPersp_ManipCheck","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please answer the following question: What was the topic of the last scenario in the game?","Choices":{"1":{"Display":"Naturalistic fallacy"},"2":{"Display":"Pseudoscience and fake expertise"},"3":{"Display":"Emotional storytelling"},"4":{"Display":"Conspiracy theories"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID328","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID329","SecondaryAttribute":"Please answer the following question: in the fourth scenario, who was the target of your conspira...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please answer the following question: in the fourth scenario, who was the target of your conspiracy theories?","DataExportTag":"EvilPersp_ManipCheck","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please answer the following question: in the fourth scenario, who was the target of your conspira...","Choices":{"1":{"Display":"Big Science"},"2":{"Display":"The WHO"},"3":{"Display":"The government"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID329","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"You are being invited to take part in an academic research study. Before you decide to participat...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"font-size: 16px; white-space: pre-wrap;\"><strong>You are being invited to take part in an academic research study. Before you decide to participate in this study, it is important that you understand why the research is being done and what it will involve. Please take the time to read the following information carefully.\n \nPurpose of the research:\n<\/strong>We are developing a free online educational game. The results of this research will inform its development. We are interested in learning more about how people evaluate online news content. <strong>\n \nStudy Procedures: \n<\/strong>\u2022 In this study, you may be asked to participate in a fictional online game. In addition, you will be asked some general questions about yourself and to evaluate and judge the reliability of social media content. \n\u2022 Your expected time commitment for this study is about 12-14 minutes. \n\u2022 You must be 18 years or older to participate in this study.<strong>\n\nBenefit and Risk: \n<\/strong>There are no benefits to participating in this study, other than the specified compensation. There are no foreseeable risks to participating in this study, but please note that we will ask you to take on the role of a fake news producer. Some of the things you read might make you feel positive or negative emotions, but no more than what you would normally encounter while reading the news or talking to other people. If you feel uncomfortable, you may stop at any time and have your participation withdrawn. The project has ethical approval from the Psychology Research Ethics Committee of the University of Cambridge.\n <strong>\nConfidentiality: \n<\/strong>Your responses in this study will be kept private, and we will not include any information that will make it possible to identify you in any report we might publish. Research records will be stored securely on password-protected computers. The results and data collected in this study may be shared with other researchers.<strong>\n \nGDPR statement:\n<\/strong>We will be using any personal information you give us in order to undertake this study and the University of Cambridge will act as the data controller for this purpose. The legal basis for using your personal information is to carry out a task (i.e. academic research) in the public interest. We will keep the information that you provide us with for as long as necessary for the study. Your rights to access, change or move your information are limited, as we need to manage your information in specific ways in order for the research to be reliable and accurate. If you withdraw from the study, we will keep the information about you that we have already obtained. To safeguard your rights, we will use the minimum personally-identifiable information possible. For further general information about the University of Cambridge\u2019s use of your personal data as a participant in a research study, please see https:\/\/www.information-compliance.admin.cam.ac.uk\/data-protection\/research-participant-data.<strong>\n\nCompensation:\n<\/strong>For participating in this study, you will receive \u00a31.75.<strong>\n  \nWho to contact with questions:\n<\/strong>This study is conducted by Dr Jon Roozenbeek, Melisa Basol and Sander van der Linden at the University of Cambridge, Ruth Appel at Stanford University, and Dr Rebecca Rayburn-Reeves and Dr Jonathan Corbin at Duke University. Study contact: Dr Jon Roozenbeek, jjr51@cam.ac.uk\n\n<strong>\nI understand the information that was presented to me and that my participation is voluntary, and I may withdraw my consent and discontinue my participation in the project at any time. My refusal will not result in any penalty. \n\nIf you wish to participate in this experiment, please click \u201cYes, I agree\u201d and continue to the next page.<\/strong><\/span>&nbsp;<\/p><div>\n<\/div>","DefaultChoices":false,"DataExportTag":"Informed consent","QuestionID":"QID33","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You are being invited to take part in an academic research study. Before you decide to participat...","Choices":{"1":{"Display":"Yes, I agree."},"2":{"Display":"No, I do not agree"}},"ChoiceOrder":[1,"2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID330","SecondaryAttribute":"Please indicate below how you feel about: misinformation about vaccinations.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate below how you feel about: <strong>misinformation about vaccinations.<\/strong>","DefaultChoices":false,"QuestionType":"Matrix","Selector":"Bipolar","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"MobileFirst":true},"QuestionDescription":"Please indicate below how you feel about: misinformation about vaccinations.","Choices":{"1":{"Display":"Non-threatening:Threatening"},"2":{"Display":"Not harmful:Harmful"},"3":{"Display":"Not dangerous:Dangerous"},"4":{"Display":"Not risky:Risky"},"5":{"Display":"Calm:Anxious"},"6":{"Display":"Not scary:Scary"}},"ChoiceOrder":["1","2","3","4","5","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":8,"Answers":{"1":{"Display":"1"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7"}},"AnswerOrder":["1","2","3","4","5","6","7"],"AnswerColumns":7,"ChoiceDataExportTags":false,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"Please indicate below how you feel about: <strong>misinformation about the coronavirus<\/strong>.&nbsp;","DataExportTag":"Threat_direct","QuestionID":"QID330"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID331","SecondaryAttribute":"Please use the scale below to indicate your level of agreement with the following statements.\u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>Please use the scale below to indicate your level of agreement with the following statements.&nbsp;<o:p><\/o:p><\/p>","DefaultChoices":false,"QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"MobileFirst":true,"RepeatHeaders":"none","WhiteSpace":"OFF"},"QuestionDescription":"Please use the scale below to indicate your level of agreement with the following statements.\u00a0","Choices":{"1":{"Display":"I want to defend my current attitudes from misinformation about vaccinations."},"2":{"Display":"I feel motivated to think about why I hold the beliefs I do about vaccinations."},"3":{"Display":"I feel motivated to resist persuasive messages about alternative accounts of vaccinations."},"4":{"Display":"I want to counter-argue conspiracy theories about vaccinations."}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":8,"ColumnLabels":[{"Display":"Strongly disagree","IsLabelDefault":false},{"Display":"Neutral","IsLabelDefault":false},{"Display":"Strongly agree","IsLabelDefault":false}],"Answers":{"1":{"Display":"1"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7"}},"AnswerOrder":["1","2","3","4","5","6","7"],"ChoiceDataExportTags":false,"QuestionText_Unsafe":"<p>Please use the scale below to indicate your level of agreement with the following statements.&nbsp;<o:p><\/o:p><\/p>","DataExportTag":"Counterarguing","QuestionID":"QID331"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID332","SecondaryAttribute":"We will now ask you to fill out a quick questionnaire. Please make sure to read the questions car...","TertiaryAttribute":null,"Payload":{"QuestionText":"We will now ask you to fill out a quick questionnaire. Please make sure to read the questions carefully and answer to the best of your knowledge.&nbsp;","DefaultChoices":false,"DataExportTag":"Welldone","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"We will now ask you to fill out a quick questionnaire. Please make sure to read the questions car...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID332"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID333","SecondaryAttribute":"Key Information This research examines how people engage with and evaluate online news content. Y...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"font-size:16px;\"><b>Key Information <\/b><\/span><\/p>\n\n<p><span style=\"font-size:16px;\">This research examines how people engage with and evaluate online news content. You will be asked a series of questions about the type of content that you would share on social media.<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:16px;\">In this study, you will be asked to evaluate and judge the credibility of social media posts, some of which may be based on factual information and some on false or misleading information. Based on your responses, you may be asked to participate in an online game that takes place in a simulated social media environment, or you may be asked to read some content. In addition, you will be asked questions about your media habits, trust in varying groups, and political views. You will also be asked questions about yourself, such as your age, gender, and political and religious affiliations.<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:16px;\">The survey should take 15 to 20 minutes to complete. After completing the survey, you will be paid $5 for your participation if you are eligible to participate in the study.<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:16px;\">We will collect your MTurk ID. We will not collect your name or any information that can be used to identify you. Although collected data may be made public or used for future research purposes, your identity will always remain confidential.<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:16px;\">The research will not benefit you personally. You will answer questions about recent events that may be upsetting, but there are no additional risks from participating in the study.<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:16px;\">Your participation is voluntary. You may withdraw at any time, and you may choose not to answer any questions, but you must proceed to the final screen of the study in order to receive your completion code which you must submit in order to be paid. In accordance with Mechanical Turk policies, we may reject your work if the HIT was not completed correctly or the instructions were not followed except where otherwise specified.<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:16px;\">If you have any questions about the research, please contact smm197@duke.edu. If you have questions about your rights as a research subject, contact Duke\u2019s Campus Institutional Review Board at campusirb@duke.edu and reference protocol ID# 2023-0081.<\/span><\/p>","DefaultChoices":{"1":{"Selected":true}},"DataExportTag":"ConsentMTurk","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Key Information This research examines how people engage with and evaluate online news content. Y...","Choices":{"1":{"Display":"Yes, I agree"},"4":{"Display":"No, I do not agree"}},"ChoiceOrder":[1,"4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID333","DisplayLogic":{"0":{"0":{"LogicType":"EmbeddedField","LeftOperand":"Source","Operator":"EqualTo","RightOperand":"MTurk","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span>  <span class=\"LeftOpDesc\">Source<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> MTurk <\/span>"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID334","SecondaryAttribute":"How much did you like or dislike the game you played?","TertiaryAttribute":null,"Payload":{"QuestionText":"How much did you like or dislike the game you played?","DataExportTag":"Game_like","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How much did you like or dislike the game you played?","Choices":{"1":{"Display":"Hated the game"},"2":{"Display":"Strongly disliked the game"},"3":{"Display":"Neutral towards the game"},"4":{"Display":"Really liked the game"},"5":{"Display":"Loved the game"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID334","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID335","SecondaryAttribute":"If you are interested in any of the options below, please select them and we will add links for t...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>If you are interested in any of the options below, please select them and we will add links for them at the end of the study (you may choose any or all of the optional links to receive):<\/div>","DataExportTag":"Interested","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If you are interested in any of the options below, please select them and we will add links for t...","Choices":{"1":{"Display":"I'd be interested in playing another version of the misinformation game for fun"},"4":{"Display":"I'd like to learn more about misinformation and how it works"},"5":{"Display":"I'd like to learn more about the COVID-19 vaccine and where I will be able to get one in my local area"},"6":{"Display":"I'm not interested in any of these options","ExclusiveAnswer":true}},"ChoiceOrder":["1","4","5","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID335","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID336","SecondaryAttribute":"Please answer how much you agree with the following statements about the game. ","TertiaryAttribute":null,"Payload":{"QuestionText":"Please answer how much you agree with the following statements about the game.&nbsp;","DefaultChoices":false,"DataExportTag":"GameFeedback","QuestionID":"QID336","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true,"ChoiceColumnWidthPixels":228},"QuestionDescription":"Please answer how much you agree with the following statements about the game. ","Choices":{"1":{"Display":"I liked the game"},"2":{"Display":"I learned something about misinformation playing this game"},"4":{"Display":"The game was easy to understand"},"5":{"Display":"I would play this game again"},"6":{"Display":"I would share this game on social media"},"7":{"Display":"I would like to challenge some friends to also give this game a try"},"8":{"Display":"I feel more confident in being able to spot misinformation after playing this game"}},"ChoiceOrder":["1","4","2","8","5","6","7"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":8,"Answers":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Neither agree nor disagree"},"6":{"Display":"Agree"},"7":{"Display":"Strongly agree"}},"AnswerOrder":["1","2","3","6","7"],"ChoiceDataExportTags":{"1":"GameFeedback_Liked","2":"GameFeedback_LearnedMisinfo","4":"GameFeedback_Easy","5":"GameFeedback_PlayAgain","6":"GameFeedback_Share","7":"GameFeedback_ChalFriends","8":"GameFeedback_SpotMisinfo"},"DataVisibility":{"Private":false,"Hidden":false},"RecodeValues":{"1":"1","2":"2","3":"3","6":"4","7":"5"}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID337","SecondaryAttribute":"Would you recommend this game to your friends and family to play? ","TertiaryAttribute":null,"Payload":{"QuestionText":"Would you recommend this game to your friends and family to play?&nbsp;","DataExportTag":"Recommend game","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Would you recommend this game to your friends and family to play? ","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"},"3":{"Display":"Not sure"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID337","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID338","SecondaryAttribute":"Check the box that fits your current status regarding the COVID-19 vaccine.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>Check the box that fits your current status regarding the COVID-19 vaccine.<\/div>","DataExportTag":"Intend Vaccinate","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Check the box that fits your current status regarding the COVID-19 vaccine.","Choices":{"1":{"Display":"I have already been vaccinated"},"2":{"Display":"I have not yet been vaccinated, but I intend to"},"6":{"Display":"I have not been vaccinated and I don't intend to"}},"ChoiceOrder":["1","2","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":7,"NextAnswerId":1,"QuestionID":"QID338","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID339","SecondaryAttribute":"Would you be willing to commit to getting vaccinated for the COVID-19 virus by signing the pledge...","TertiaryAttribute":null,"Payload":{"QuestionText":"Would you be willing to commit to getting vaccinated for the COVID-19 virus by signing the pledge below?<div><br><\/div><div>Pledge:&nbsp;<\/div><div><i><br><\/i><\/div><div><i>I hereby commit to getting vaccinated for the COVID-19 virus when it becomes available to me to do so.&nbsp;<\/i><\/div>","DataExportTag":"Pledge","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Would you be willing to commit to getting vaccinated for the COVID-19 virus by signing the pledge...","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID339","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID340","SecondaryAttribute":"What is your marital status? ","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your marital status?&nbsp;","DataExportTag":"Marital status","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","Autoscale":{"YScale":{"Name":"marital","Type":"likert","Reverse":false}}},"QuestionDescription":"What is your marital status? ","Choices":{"10":{"Display":"Married"},"11":{"Display":"Widowed"},"12":{"Display":"Divorced"},"13":{"Display":"Separated"},"14":{"Display":"Never married"}},"ChoiceOrder":["10","11","12","13","14"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"Language":[],"NextChoiceId":15,"NextAnswerId":1,"QuestionID":"QID340","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID341","SecondaryAttribute":"Do you have any children? ","TertiaryAttribute":null,"Payload":{"QuestionText":"Do you have any children?&nbsp;","DataExportTag":"Have_children","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Do you have any children? ","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID341","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID342","SecondaryAttribute":"What age is your youngest child? ","TertiaryAttribute":null,"Payload":{"QuestionText":"What age is your youngest child?&nbsp;","DataExportTag":"Child_age","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What age is your youngest child? ","Choices":{"1":{"Display":"Under 1 year old"},"2":{"Display":"Under 2 years old"},"4":{"Display":"Under 3 years old"},"5":{"Display":"Under 5 years old"},"6":{"Display":"Under 10 years old"},"7":{"Display":"Over 10 years old"}},"ChoiceOrder":["1","2","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID342","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID341\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Do you have any children? <\/span> <span class=\"LeftOpDesc\">Yes<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID341\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID341","QuestionIDFromLocator":"QID341","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID343","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"DataExportTag":"Q83","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID343"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID344","SecondaryAttribute":"Please sign your initials below to complete your pledge!","TertiaryAttribute":null,"Payload":{"QuestionText":"Please sign your initials below to complete your pledge!","DefaultChoices":false,"DataExportTag":"Initials","QuestionType":"Draw","Selector":"Signature","Configuration":{"QuestionDescriptionOption":"UseText","ShowBackgroundText":true,"BoxSize":"Medium"},"QuestionDescription":"Please sign your initials below to complete your pledge!","Validation":{"Settings":{"ForceResponse":"ON"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID344","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID339\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Would you be willing to commit to getting vaccinated for the COVID-19 virus by signing the pledge...<\/span> <span class=\"LeftOpDesc\">Yes<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID339\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID339","QuestionIDFromLocator":"QID339","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID345","SecondaryAttribute":"Thanks! We'd now like to ask you a few questions about vaccination and the COVID-19 pandemic. ","TertiaryAttribute":null,"Payload":{"QuestionText":"Thanks! We'd now like to ask you a few questions about vaccination and the COVID-19 pandemic.&nbsp;","DefaultChoices":false,"DataExportTag":"COVID Questions","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thanks! We'd now like to ask you a few questions about vaccination and the COVID-19 pandemic. ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID345","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID346","SecondaryAttribute":"You indicated you were interested in playing another version of the misinformation game. Here is...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,serif;\nmso-fareast-font-family:Arial;mso-ansi-language:EN-US;mso-fareast-language:\nEN-US;mso-bidi-language:AR-SA\">You indicated you were interested in playing another version of the misinformation game. Here is a link to Go Viral, a game about COVID-19 misinformation. <\/span><span style=\"font-size:12.0pt\"><span style=\"font-family:&quot;Times New Roman&quot;,serif\">This link will open in a new window; make sure to return to this survey to get your completion code<\/span><\/span><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,serif;\nmso-fareast-font-family:Arial;mso-ansi-language:EN-US;mso-fareast-language:\nEN-US;mso-bidi-language:AR-SA\">:&nbsp;<a href=\"https:\/\/www.goviralgame.com\/\" target=\"_blank\">https:\/\/www.goviralgame.com\/<\/a>&nbsp;&nbsp;<\/span>","DefaultChoices":false,"DataExportTag":"Interest-Goviral","QuestionID":"QID346","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You indicated you were interested in playing another version of the misinformation game. Here is...","DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID335\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">If you are interested in any of the options below, please select them and we will add links for t...<\/span> <span class=\"LeftOpDesc\">I'd be interested in playing another version of the misinformation game for fun<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID335\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID335","QuestionIDFromLocator":"QID335","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false},"ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID347","SecondaryAttribute":"You indicated you were interested in learning more about the COVID-19 vaccine and where you will...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,serif;\nmso-fareast-font-family:Arial;mso-ansi-language:EN-US;mso-fareast-language:\nEN-US;mso-bidi-language:AR-SA\">You indicated you were interested in learning more about the COVID-19 vaccine and where you 