34","35","36"],"Answers":{"32":{"Display":"Not at all profound"},"33":{"Display":"Somewhat profound"},"34":{"Display":"Fairly profound"},"35":{"Display":"Definitely profound"},"36":{"Display":"Very profound"}},"ChoiceDataExportTags":false,"ChoiceGroupOrder":["cg_1","cg_2","cg_3"],"ChoiceGroups":{"cg_1":{"ChoiceGroupOrder":["13","14","15","17"],"GroupLabel":"Mundane","Options":{"HideTitle":false}},"cg_2":{"ChoiceGroupOrder":["10","1","2","11"],"GroupLabel":"BS","Options":{"HideTitle":false}},"cg_3":{"ChoiceGroupOrder":["19","7","21","23"],"GroupLabel":" Motivate","Options":{"HideTitle":false}}},"ChoiceOrder":["13","14","15","17","10","1","2","11","19","7","21","23"],"Choices":{"1":{"Display":"Every material particle is a relationship of probability waves in a field of infinite possibilities. You are that."},"2":{"Display":"Perceptual reality transcends subtle truth."},"7":{"Display":"A river cuts through a rock, not because of its power but its persistence."},"10":{"Display":"We are not an emergent property of a mechanical cosmos."},"11":{"Display":"As you self-actualize, you will enter into infinite empathy that transcends understanding."},"13":{"Display":"People often have very bizarre dreams."},"14":{"Display":"Human cultures often differ from each other quite a bit."},"15":{"Display":"A balanced diet is important for maintaining good health."},"17":{"Display":"Higher rates of unemployment typically follow economic downturns."},"19":{"Display":"All endings are also beginnings. We just don't know it at the time."},"21":{"Display":"Only those who will risk going too far can possibly find out how far one can go."},"23":{"Display":"I wonder how many people I\u2019ve looked at all my life and never seen."}},"Configuration":{"ChoiceColumnWidth":25,"MobileFirst":true,"QuestionDescriptionOption":"UseText","RepeatHeaders":"none","TextPosition":"inline","WhiteSpace":"OFF"},"DataExportTag":"BSReceptivityScale","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices