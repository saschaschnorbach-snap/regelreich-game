ionDescription":"In a scratch card lottery, the chance of winning a $10 prize is 1%. What is your best guess about...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID309","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID310","SecondaryAttribute":"At a raffle, the chance of winning a car is 1 in 1,000. What percentage of tickets in the raffle...","TertiaryAttribute":null,"Payload":{"QuestionText":"At a raffle, the chance of winning a car is 1 in 1,000. What percentage of tickets in the raffle win a car? ___ %","DefaultChoices":false,"DataExportTag":"Schwartz-3","QuestionID":"QID310","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":59,"InputHeight":29},"QuestionDescription":"At a raffle, the chance of winning a car is 1 in 1,000. What percentage of tickets in the raffle...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID311","SecondaryAttribute":"Which represents the highest risk of something happening?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which represents the highest risk of something happening?","DataExportTag":"Risk assessment","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which represents the highest risk of something happening?","Choices":{"1":{"Display":"1 in 10"},"2":{"Display":"1 in 1000"},"3":{"Display":"1 in 100"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","Forc