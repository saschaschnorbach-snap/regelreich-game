,"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID314","SecondaryAttribute":"This study requires you to be able to play both audio and video in your browser window. Please en...","TertiaryAttribute":null,"Payload":{"QuestionText":"This study requires you to be able to play both <b>audio<\/b> and <b>video<\/b> in your browser window. Please ensure that playing audio and video (such as YouTube videos) is enabled in your browser.","DefaultChoices":false,"DataExportTag":"AudVidExplainer","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This study requires you to be able to play both audio and video in your browser window. Please en...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID314","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID315","SecondaryAttribute":"Before you start,\u00a0please switch off your phone\/music\/email\u00a0so that you can fully focus on the stu.","TertiaryAttribute":null,"Payload":{"QuestionText":"Before you start,&nbsp;<span style=\"font-weight: bolder;\">please switch off your phone\/music\/email<\/span>&nbsp;so that you can fully focus on the study. This study features&nbsp;<span style=\"font-weight: bolder;\">attention checks<\/span>&nbsp;to ensure your attentive participation in this study.","DefaultChoices":false,"DataExportTag":"AttentionCheck","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Before you start,\u00a0please switch off your phone\/music\/email\u00a0so that you can fully focus on the stu...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"