","3","4","5","6"],"Answers":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Disagree"},"3":{"Display":"Somewhat disagree"},"4":{"Display":"Somewhat agree"},"5":{"Display":"Agree"},"6":{"Display":"Strongly agree"}},"ChoiceDataExportTags":{"1":"CtlTrueBW2_Share","2":"CtlTrueBW2_Like","3":"CtlTrueBW2_Accuracy","4":"CtlTrueBW2_Manip","5":"CtlTrueBW2_ManipConf"},"ChoiceOrder":["4","5","3","1","2"],"Choices":{"1":{"Display":"I would share this post on social media"},"2":{"Display":"I would 'like' this post on social media"},"3":{"Display":"This is an accurate post"},"4":{"Display":"This is a manipulative post"},"5":{"Display":"I am confident in my assessment of this post's manipulativeness"}},"Configuration":{"ChoiceColumnWidth":25,"MobileFirst":true,"QuestionDescriptionOption":"UseText","RepeatHeaders":"none","TextPosition":"inline","WhiteSpace":"OFF"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":7,"NextChoiceId":8,"QuestionDescription":"${q:\/\/QID446\/QuestionText} In a January 12 2022 Quinnipiac poll, U.S. President Joe Biden's appro...","QuestionText":"${q:\/\/QID446\/QuestionText}<strong><i> <\/i><br>\nIn a January 12 2022 Quinnipiac poll, U.S. President Joe Biden's approval rating plummeted to just above 30 percent. <\/strong><br>\n<br>\nFor the content above, to what extent do you agree with the following statements?","QuestionText_Unsafe":"${q:\/\/QID446\/QuestionText}<strong><i> <\/i><br>\nIn a January 12 2022 Quinnipiac poll, U.S. President Joe Biden's approval rating plummeted to just above 30 percent.<\/strong><br>\n<br>\nFor the content above, to what extent do you agree with the following statements?","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"RecodeValues":{"1":"-3","2":"-2","3":"-1","4":"1","5":"2","6":"3"},"DataExportTag":"CtlTrueBW2