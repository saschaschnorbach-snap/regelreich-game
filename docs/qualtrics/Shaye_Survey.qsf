might have, the coronavirus\/COVID-19?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"},"4":{"Display":"Unsure"},"5":{"Display":"Prefer not to say"}},"ChoiceOrder":["1","2","4","5"],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID317"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID319","SecondaryAttribute":"US_region","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_3mcIQjnv2EKglq6\" style=\"width: 700px; height: 417px;\"><\/p><p><br><\/p><p>Based on the map above, in which region of the US do you currently reside?<\/p>","DataExportTag":"US_Region","QuestionType":"MC","Selector":"SAVR","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"SpecifyLabel"},"QuestionDescription":"US_region","Choices":{"1":{"Display":"West"},"2":{"Display":"Mid-West"},"3":{"Display":"South"},"4":{"Display":"North-East"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None"}},"Language":[],"NextChoiceId":54,"NextAnswerId":1,"QuestionID":"QID319","DefaultChoices":false,"SubSelector":"TX","GradingData":[]}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID320","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":420,"MaxSeconds":1500,"Seconds":10},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":4376,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"BadVaxxeviltimer","QuestionID":"QID320"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID321","SecondaryAttribute":"Your next objective is to complete a game. In the frame underneath you can start. The game takes...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>Your next objective is to complete a game. In the frame underneath you can start. The game takes approximately 12-15 minutes to complete. At the end of the game, you will receive a secret password consisting of four letters and four digits. <strong>You will have to enter this password below in order for your participation to be approved and to continue to the next page!<\/strong>&nbsp;<strong>But p<\/strong><strong>lease bear in mind that the password is not the same as your Prolific completion code. <\/strong>You will receive your completion code after completing the entire survey.<strong>&nbsp;<\/strong><\/div>\n\n<div>&nbsp;<\/div>\n\n<div><b>The proceed-button will only appear after a minimum of 10 minutes of attentive play. After about 16 minutes, this screen will automatically progress to the next page.&nbsp;<\/b>It is important that you play this game attentively. If you rush through it without thinking about it properly, you will not be able to continue to the next page.&nbsp;<\/div>\n\n<div>&nbsp;<\/div>\n\n<div>&nbsp;<\/div>\n\n<div class=\"resp-container\"><em><iframe allow=\"encrypted-media\" allowfullscreen=\"\" class=\"resp-iframe\" frameborder=\"0\" gesture=\"media\" scrolling=\"no\" src=\"https:\/\/badvaxx.aboutbadnews.com\/book\/default-book\/\"><\/iframe><\/em><\/div>\n\n<div><em>---<br>\n<strong>PASSWORD<\/strong><\/em><\/div>","DefaultChoices":false,"DataExportTag":"BadVaxxEvil","QuestionID":"QID321","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":145,"InputHeight":29},"QuestionDescription":"Your next objective is to complete a game. In the frame underneath you can start. The game takes...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":1,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID322","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"DefaultChoices":false,"QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"Choices":{"1":{"Display":"This post is manipulative"},"2":{"Display":"I am confident about my assessment of this post's manipulativeness"},"3":{"Display":"I would share this post with people in my network"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":8,"ColumnLabels":[{"Display":"Strongly disagree","IsLabelDefault":false},{"Display":"Neutral","IsLabelDefault":false},{"Display":"Strongly agree","IsLabelDefault":false}],"Answers":{"1":{"Display":"1"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7"}},"AnswerOrder":["1","2","3","4","5","6","7"],"ChoiceDataExportTags":false,"QuestionText":"<img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_bO6KEP91hdB0sp7\" style=\"width: 499px; height: 103px;\" \/>","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":" ","QuestionText_Unsafe":"<img src=\"https:\/\/cambridge.eu.qualtrics.com\/\/CP\/Graphic.php?IM=IM_3mTkRyBuklq4cIZ\" style=\"width: 500px; height: 112px;\" \/>","DataExportTag":"Story-VaccineCourt","QuestionID":"QID322"}},{"SurveyID":"SV_43dIH6kWw5pRcto","Element":"SQ","PrimaryAttribute":"QID323","SecondaryAttribute":" ","TertiaryAttribute":nu